{
  "name": "pi-memctx",
  "version": "0.1.0",
  "description": "Automatic local-first memory context injection for Pi coding agents using Markdown packs.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-coding-agent",
    "agent-memory",
    "memory",
    "context-injection",
    "local-first",
    "markdown",
    "obsidian"
  ],
  "license": "MIT",
  "type": "module",
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*",
    "@types/bun": "^1.3.13"
  },
  "scripts": {
    "test": "bun test test/",
    "test:e2e": "bun run test/e2e.ts",
    "typecheck": "tsc --noEmit",
    "ci": "npm run typecheck && npm test && npm run test:e2e"
  },
  "homepage": "https://github.com/weauratech/pi-memctx#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weauratech/pi-memctx.git"
  },
  "bugs": {
    "url": "https://github.com/weauratech/pi-memctx/issues"
  },
  "author": "WeAura Tech",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "index.ts",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ]
}
