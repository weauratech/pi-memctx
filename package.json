{
  "name": "pi-memctx",
  "version": "0.2.0",
  "description": "Automatic memory context injection for pi coding agent. Load, search, and persist knowledge across sessions using Markdown packs.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-coding-agent",
    "agent-memory",
    "memory",
    "context-injection",
    "local-first",
    "markdown",
    "obsidian",
    "ai-agents",
    "coding-agent"
  ],
  "license": "MIT",
  "type": "module",
  "author": "Magno Oliveira <magnonta@outlook.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weauratech/pi-memctx.git"
  },
  "homepage": "https://github.com/weauratech/pi-memctx#readme",
  "bugs": {
    "url": "https://github.com/weauratech/pi-memctx/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "index.ts",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "docs",
    "benchmark/"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49"
  },
  "optionalDependencies": {
    "@tobilu/qmd": "^2.1.0"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@types/bun": "^1.3.13"
  },
  "scripts": {
    "test": "bun test test/",
    "test:e2e": "bun run test/e2e.ts",
    "typecheck": "tsc --noEmit",
    "ci": "npm run typecheck && npm test && npm run test:e2e"
  }
}
